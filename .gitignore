.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Secrets and credentials ────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ── Claude Code session data ───────────────────────────────────────────────────
.claude/

# ── OS junk ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ───────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

